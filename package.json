{
  "name": "spssread",
  "version": "0.1.0",
  "description": "Correct, zero-dependency SPSS .sav/.zsav reader for the browser and Node — validated against R haven.",
  "license": "MIT",
  "author": "everydaydesign",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "engines": { "node": ">=18" },
  "keywords": ["spss", "sav", "zsav", "parser", "reader", "browser", "statistics", "haven", "pspp", "data"],
  "repository": { "type": "git", "url": "git+https://github.com/everydaydesign/spssread.git" },
  "homepage": "https://github.com/everydaydesign/spssread#readme",
  "bugs": "https://github.com/everydaydesign/spssread/issues",
  "scripts": {
    "build": "tsup",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "fixtures": "Rscript oracle/generate-fixtures.R",
    "prepublishOnly": "tsup && bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2"
  }
}
